# PlantCraft Environment Variables
# Copy this file to .env.local and fill in your values

# ===== GEMINI AI (Phase 3 — Plant Disease Diagnosis) =====
# Get your API key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ===== FIREBASE (Phase 5 — Shared AR / QR Code) =====
# Get values from: Firebase Console → Project Settings → Your apps
# Choose region asia-southeast1 (Singapore) for best latency in Vietnam
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_DATABASE_URL=https://your-project-default-rtdb.asia-southeast1.firebasedatabase.app
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abcdef
